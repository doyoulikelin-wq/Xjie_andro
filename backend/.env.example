APP_ENV=dev
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/metabodash
REDIS_URL=redis://redis:6379/0

S3_ENDPOINT_URL=http://minio:9000
S3_BUCKET=metabodash
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_PUBLIC_BASE_URL=http://localhost:9000/metabodash
LOCAL_STORAGE_DIR=/tmp/metabodash_uploads

LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.moonshot.cn/v1
OPENAI_MODEL_TEXT=moonshot-v1-8k
OPENAI_MODEL_VISION=moonshot-v1-8k
GEMINI_API_KEY=
GEMINI_MODEL_TEXT=gemini-1.5-pro
GEMINI_MODEL_VISION=gemini-1.5-pro

JWT_SECRET=change_me
JWT_EXPIRES_MIN=1440
CORS_ORIGINS=http://localhost:5173
API_BASE_URL=http://localhost:8000

# CGM integration (webhook / push)
CGM_PROVIDER_NAME=vendor_cgm
CGM_SHARED_SECRET=
CGM_ALLOW_UNSIGNED=true
CGM_DEVICE_TIMEZONE=Asia/Shanghai
CGM_SOURCE_NAME=cgm_device_api
